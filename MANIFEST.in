include LICENSE
include README.md
include pyproject.toml
exclude SKILL.md
recursive-include aaaat *.py *.sql
include aaaat/SKILL.md

# A release artifact contains the runnable application and its metadata, not
# repository-only review material that a locally capable host could browse.
prune tests
prune docs
prune work
prune .agents
prune .codex
prune examples
prune launchers
prune scripts
prune tools
global-exclude __pycache__
global-exclude *.py[cod]
