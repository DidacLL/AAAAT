# AAAAT private/local data - never commit
.private/
.private/**
*.sqlite
*.sqlite3
*.db

# Python generated files
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.mypy_cache/
.ruff_cache/
.venv/
venv/

# Local outputs
outputs/
local/
tmp/
*.tmp

